# Environment variables for the project
PROJECT_NAME=your_project_name_here

# Database configuration
DATABASE_URL=your_database_url_here
DATABASE_USER=your_database_user_here
DATABASE_PASSWORD=your_database_password_here

# Email configuration
EMAIL_HOST=your_email_host_here
EMAIL_PORT=your_email_port_here
EMAIL_USER=your_email_user_here
EMAIL_PASSWORD=your_email_password_here

# Resend API Key for sending emails
RESEND_API_KEY=your_resend_api_key_here

# Whatsapp API Key for sending messages
WHATSAPP_API_KEY=your_whatsapp_api_key_here
WHATSAPP_PHONE_NUMBER=your_whatsapp_phone_number_here

# Google Maps API Key for location services
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google Analytics API Key for tracking and analytics
GOOGLE_ANALYTICS_API_KEY=your_google_analytics_api_key_here

# Open AI API Key for AI functionalities
OPENAI_API_KEY=your_openai_api_key_here

# Additional environment variables can be added below as needed
