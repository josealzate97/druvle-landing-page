---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import Footer from "../../components/Footer.astro";
import ContactSection from "../../components/ContactSection.astro";
---

<BaseLayout
  title="DRUVLE MENU | Druvle"
  description="Características principales del sistema de menús de Druvle, diseñado para ventas rápidas y control en tiempo real."
>
  <SiteHeader />

  <main>
    <section class="section">
      <div class="container">
        <div class="section-title">
          <p class="eyebrow">DRUVLE MENU</p>
          <h1>
            Un sistema de menús integrado que se conecta directamente con el
            inventario, para ventas rápidas y control en tiempo real.
          </h1>
          <p>
            Esta página refuerza los beneficios de Druvle con bloques claros,
            útiles para SEO y para explicar valor a primera vista.
          </p>

          <div class="hero-actions" style="justify-content:flex-start">
            <a class="button button-dark" href="/druvle-menus/planes">
              Ver planes
            </a>
          </div>
        </div>

        <div class="feature-grid"></div>
      </div>
    </section>

    <ContactSection />
  </main>

  <Footer />
</BaseLayout>
