---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Productos | Druvle"
  description="Descubra los productos de Druvle, diseñados para ofrecer control, trazabilidad y una experiencia clara en la gestión de inventarios."
>
  <SiteHeader />

  <main>
    <section class="section">
      <div class="container">
        <div class="section-title">
          <p class="eyebrow">Conozca nuestros productos</p>
          <h1>
            Todo lo que necesita una operación para tener inventario bajo
            control.
          </h1>
          <p>
            Descubra cómo nuestros productos pueden mejorar la eficiencia y el
            control de su inventario, ofreciendo soluciones claras y efectivas.
          </p>
        </div>

        <div class="feature-grid">
          <article class="feature-card">
            <h2>Druvle ERP</h2>
            <p>
              Un sistema de gestión de inventarios completo para controlar cada
              movimiento, con trazabilidad total y una experiencia clara.
            </p>

            <a href="/druvle-erp" class="button button-ghost read-more">
              Ver características
            </a>
          </article>

          <article class="feature-card">
            <h2>Druvle Menus</h2>
            <p>
              Un sistema de menús integrado que se conecta directamente con el
              inventario, para ventas rápidas y control en tiempo real.
            </p>

            <a href="/druvle-menus" class="button button-ghost read-more">
              Ver características
            </a>
          </article>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
