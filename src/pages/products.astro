---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Productos | Druvle"
  description="Descubra los productos de Druvle, diseñados para ofrecer control, trazabilidad y una experiencia clara en la gestión de inventarios."
>
  <SiteHeader />

  <main>
    <section class="section">
      <div class="container">
        <div class="section-title">
          <p class="eyebrow">Características</p>
          <h1>
            Todo lo que necesita una operación para tener inventario bajo
            control.
          </h1>
          <p>
            Esta página refuerza los beneficios de Druvle con bloques claros,
            útiles para SEO y para explicar valor a primera vista.
          </p>
        </div>

        <div class="feature-grid"></div>
      </div>
    </section>
  </main></BaseLayout
>
