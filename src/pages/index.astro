---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import Footer from "../components/Footer.astro";
import ContactSection from "../components/ContactSection.astro";

const stats = [
  { value: "+100%", label: "Visibilidad del inventario en una sola vista" },
  { value: "+24/7", label: "Control sobre movimientos, entradas y salidas" },
  { value: "0 fricción", label: "Para equipos que necesitan operar rápido" },
];

const highlights = [
  "Control de stock en tiempo real",
  "Alertas de reposición",
  "Panel claro para compras y ventas",
  "Historial por usuario y producto",
  "Reportes para decisiones rápidas",
  "Diseñado para crecer con tu operación",
];

const clients = [
  { name: "PHILIPS", id: "philips" },
  { name: "Siemens", id: "siemens" },
  { name: "DM", id: "dm" },
  { name: "Paysafe", id: "paysafe" },
];
---

<BaseLayout
  title="Druvle | Software de inventario"
  description="Landing oficial de Druvle, software de inventario para controlar stock, compras y ventas con una experiencia clara y moderna."
>
  <SiteHeader />

  <main>
    <section class="hero">
      <div class="container hero-grid">
        <div>
          <p class="eyebrow">Gestión de inventario</p>
          <h1>Ordena tu inventario con una vista clara, rápida y confiable.</h1>
          <p class="hero-lead">
            Druvle centraliza el control de stock, compras, ventas y alertas
            para que tu equipo reduzca errores y tome decisiones con datos
            reales.
          </p>

          <div class="hero-actions">
            <a class="button button-dark" href="/planes">Comenzar ahora</a>
            <a class="button button-ghost" href="/#contacto">Pedir una demo</a>
          </div>
        </div>

        <div class="hero-panel" aria-label="Vista previa del producto">
          <div class="dashboard">
            <div class="dashboard-top">
              <div>
                <p class="eyebrow">Panel activo</p>
                <h2>Resumen operativo</h2>
              </div>
              <span class="chip">Actualizado hace 2 min</span>
            </div>

            <div class="chips">
              <span class="chip">Stock bajo</span>
              <span class="chip">Pedidos por revisar</span>
              <span class="chip">Movimientos del día</span>
            </div>

            <div class="metrics" style="margin-top: 1rem;">
              <div class="metric">
                <span class="eyebrow">Productos críticos</span>
                <strong>18</strong>
              </div>
              <div class="metric">
                <span class="eyebrow">Entradas hoy</span>
                <strong>124</strong>
              </div>
              <div class="metric">
                <span class="eyebrow">Ventas hoy</span>
                <strong>89</strong>
              </div>
              <div class="metric">
                <span class="eyebrow">Exactitud</span>
                <strong>98%</strong>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="stats-grid">
          {
            stats.map((stat) => (
              <article class="stat-card">
                <strong>{stat.value}</strong>
                <p>{stat.label}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section clients-section">
      <div class="container">
        <p class="eyebrow" style="text-align: center; margin-bottom: 1.5rem;">
          Confiado por empresas líderes
        </p>
        <div class="clients-grid">
          {
            clients.map((client) => (
              <div class="client-logo" aria-label={client.name}>
                <span>{client.name}</span>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section tech-section">
      <div class="container">
        <div class="tech-content">
          <p class="eyebrow">Nuestra tecnología</p>
          <h2>Construida para resolver desafíos del mundo real</h2>
          <p>
            Ya sea que busques reducir costos de inventario, eliminar errores
            manuales, o simplemente operar con más velocidad, tu equipo será
            capaz de hacerlo con Druvle. Diseñado para empresas que necesitan
            controlar, escalar y crecer.
          </p>
        </div>

        <div class="feature-grid">
          {
            highlights.map((item) => (
              <article class="feature-card">
                <h3>{item}</h3>
                <p>
                  Herramientas diseñadas para explicar valor sin saturar,
                  manteniendo una experiencia ágil en desktop y móvil.
                </p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <ContactSection />
  </main>

  <Footer />
</BaseLayout>
