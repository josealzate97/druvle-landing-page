---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Nosotros | Druvle"
  description="Conozca más sobre nuestro equipo y nuestra misión en Druvle, enfocados en control, trazabilidad y experiencia clara."
>
  <SiteHeader />

  <main>
    <section class="section">
      <div class="container">
        <div class="section-title">
          <p class="eyebrow">Sobre Nosotros</p>
          <h1>Conozca más sobre nuestro equipo y nuestra misión.</h1>
          <p>
            Esta página refuerza los beneficios de Druvle con bloques claros,
            útiles para SEO y para explicar valor a primera vista.
          </p>
        </div>

        <div class="feature-grid"></div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
