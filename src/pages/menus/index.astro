---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import Footer from "../../components/Footer.astro";
---

<BaseLayout
  title="Menús | Druvle"
  description="Características principales del sistema de menús de Druvle, diseñado para ventas rápidas y control en tiempo real."
>
  <SiteHeader />

  <main>
    <section class="section">
      <div class="container">
        <div class="section-title">
          <p class="eyebrow">Menús</p>
          <h1>
            Un sistema de menús integrado que se conecta directamente con el
            inventario, para ventas rápidas y control en tiempo real.
          </h1>
          <p>
            Esta página refuerza los beneficios de Druvle con bloques claros,
            útiles para SEO y para explicar valor a primera vista.
          </p>
        </div>

        <div class="feature-grid"></div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
